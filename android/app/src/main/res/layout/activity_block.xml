<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#FDEAEA">

    <TextView
        android:id="@+id/blockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="App bloqueada"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#C62828"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/blockPackage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Package:"
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esta app está restringida."
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Usá este tiempo para leer, estudiar, hacer ejercicio o meditar."
        android:textSize="16sp"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/requestUnlockButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solicitar desbloqueo"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/closeButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Volver" />

</LinearLayout>
